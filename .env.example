DATABASE_URL=postgres://postgres:password@localhost:5432/books-store
REDIS_URL=redis://localhost:6379
PORT=3010
NODE_ENV=production
LOG_LEVEL=info
CRON_SCHEDULE="0 3 * * *"
GOOGLE_API_KEYS="key1,key2,key3"
DAILY_REQUEST_LIMIT=1000
MAX_ATTEMPTS=3
CAN_USE_OPENLIBRARY_API=true
ACTION=update-metadata
REQUEST_DELAY_MS=2000
