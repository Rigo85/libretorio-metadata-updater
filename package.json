{
    "name": "libretorio-metadata-updater",
    "version": "1.0.0",
    "description": "Enriches archive records with metadata from OpenLibrary and Google Books APIs.",
    "scripts": {
        "start": "npm run serve",
        "serve": "node dist/server.js",
        "debug": "nodemon --inspect-brk=0.0.0.0:9229 dist/server.js",
        "watch-node": "nodemon dist/server.js",
        "watch": "concurrently -k -p \"[{name}]\" -n \"TypeScript,Node\" -c \"cyan.bold,green.bold\" \"npm run watch-ts\" \"npm run watch-node\"",
        "watch-ts": "tsc -w",
        "build": "npm run build-ts && npm run lint && npm run copy-static-assets",
        "copy-static-assets": "ts-node copyStaticAssets.ts",
        "build-ts": "tsc",
        "lint": "eslint -c .eslintrc.js --ext .ts src/**/*.ts",
        "lint-fix": "eslint --fix src/**/*.ts",
        "postinstall": "npm run build"
    },
    "keywords": [],
    "author": "Rigoberto L. Salgado Reyes <rlsalgado2006@gmail.com>",
    "license": "AGPL-3.0",
    "engines": {
        "node": "20.x"
    },
    "overrides": {
        "minimatch": ">=10.2.4"
    },
    "dependencies": {
        "axios": "^1.7.2",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "errorhandler": "^1.5.1",
        "express": "^4.18.2",
        "fs-extra": "^11.2.0",
        "helmet": "^7.1.0",
        "lusca": "^1.7.0",
        "module-alias": "^2.2.3",
        "moment-timezone": "^0.5.45",
        "node-cron": "^3.0.3",
        "pg": "^8.11.3",
        "pino": "^9.6.0",
        "pino-pretty": "^13.0.0",
        "string-similarity": "^4.0.4"
    },
    "devDependencies": {
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.16",
        "@types/errorhandler": "^1.5.3",
        "@types/express": "^4.17.19",
        "@types/fs-extra": "^11.0.4",
        "@types/lusca": "^1.7.4",
        "@types/node": "^20.8.5",
        "@types/pg": "^8.10.9",
        "@types/string-similarity": "^4.0.2",
        "@typescript-eslint/eslint-plugin": "^6.7.5",
        "@typescript-eslint/parser": "^6.7.5",
        "concurrently": "^8.2.2",
        "eslint": "^8.51.0",
        "eslint-plugin-jsdoc": "^46.8.2",
        "eslint-plugin-no-null": "^1.0.2",
        "nodemon": "^3.0.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.2.2"
    }
}
